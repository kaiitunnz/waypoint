# Copy this to .env at the repo root. Both waypointctl (canonical) and
# scripts/waypoint.sh (legacy) load it. Every value below is shown at
# its default — uncomment a line only to override.
#
# Values are treated as literal strings: `$VAR` interpolation and
# `$(...)` substitution are not evaluated. Surrounding single or
# double quotes are stripped.

# Required before exposing the service beyond localhost.
# WAYPOINT_PASSWORD=change-me

# ─── Stack supervisor ────────────────────────────────────────────────
# Network
# WAYPOINT_STACK_BACKEND_HOST=0.0.0.0
# WAYPOINT_STACK_BACKEND_PORT=8787
# WAYPOINT_STACK_FRONTEND_PORT=3000
# WAYPOINT_STACK_CONTROL_HOST=0.0.0.0    # waypointd out-of-band remote-control console
# WAYPOINT_STACK_CONTROL_PORT=8799       # 0 disables; only served while waypointd runs

# Paths (relative paths resolve under the repo root)
# WAYPOINT_STACK_CONFIG=backend/waypoint.yaml
# WAYPOINT_STACK_BACKEND_DATA_DIR=~/.waypoint/backend-data
# WAYPOINT_STACK_UV_CACHE_DIR=~/.waypoint/uv-cache

# Behavior
# WAYPOINT_STACK_FRONTEND_DEV=0           # 1 = `npm run dev` instead of build+start
# WAYPOINT_STACK_START_TIMEOUT=30         # seconds to wait for health probes
# WAYPOINT_STACK_FORCE_FRONTEND_BUILD=0   # 1 = rebuild even if the cache is fresh
# WAYPOINT_STACK_CAFFEINATE=1             # macOS only: hold `caffeinate -i -s`

# ─── waypointctl only (ignored by scripts/waypoint.sh) ───────────────
# WAYPOINTCTL_STATE_DIR=~/.waypoint       # pid/log/socket root
# WAYPOINTCTL_DAEMON=0                    # 1 = always route through waypointd

# ─── Notifications ────────────────────────────────────────────────────
# Bot token for the opt-in Telegram notification center. Read from the env
# var named by `notifications.channels[].bot_token_env` in
# backend/waypoint.yaml (this is that default name). Only used when
# `notifications.enabled` is true there. Keep it empty here — never commit a
# real token. See docs/telegram-notifications.md.
# WAYPOINT_TELEGRAM_BOT_TOKEN=

# ─── Usage providers ──────────────────────────────────────────────────
# Lumid personal-access token(s) for the opt-in usage provider. Read from the
# env var named by `usage_providers[].token_env` in backend/waypoint.yaml
# (this is that default name). Comma-separate multiple PATs. Only used when a
# `usage_providers` block is enabled there. Keep it empty here — never commit a
# real token. See docs/usage-providers.md.
# LUMID_TOKENS=

# ─── tailscale helper ─────────────────────────────────────────────────
# Used by `waypointctl tailscale` and `scripts/waypoint_tailscale.sh` for
# Docker-backed Tailscale profiles.
# TS_AUTHKEY=tskey-auth-...
# TS_HOSTNAME=waypoint-profile-a
# TS_IMAGE=tailscale/tailscale:latest
# TS_HOST_ALIAS=host.docker.internal     # override on hosts where host-gateway resolves differently
#
# Peer discovery (login screen + backend switcher) exec's into the tailscale
# sidecar this deployment owns. It resolves the container from the active
# profile recorded under `$WAYPOINTCTL_STATE_DIR/tailscale` by
# `waypointctl tailscale up`, so no extra configuration is needed even when
# unrelated `waypoint.role=tailscale` containers share the host.
