# Repo-local defaults honored by both waypointctl (canonical) and
# scripts/waypoint.sh (legacy). Copy to .env and adjust as needed.

# Stack supervisor settings
WAYPOINT_STACK_BACKEND_HOST=0.0.0.0
WAYPOINT_STACK_BACKEND_PORT=8787
WAYPOINT_STACK_FRONTEND_PORT=3000
WAYPOINT_STACK_FRONTEND_DEV=0
WAYPOINT_STACK_START_TIMEOUT=30
WAYPOINT_STACK_CONFIG=backend/waypoint.yaml
WAYPOINT_STACK_BACKEND_DATA_DIR=tmp/waypoint/backend-data
WAYPOINT_STACK_UV_CACHE_DIR=tmp/waypoint/uv-cache
WAYPOINT_STACK_FORCE_FRONTEND_BUILD=0
WAYPOINT_STACK_CAFFEINATE=1

# waypointctl settings (ignored by scripts/waypoint.sh)
# Where waypointctl keeps pid/log files and default data dirs.
# WAYPOINTCTL_STATE_DIR=~/.waypoint
# Route every waypointctl command through the long-lived waypointd daemon,
# auto-starting it if needed. Off by default; daemon is opt-in.
# WAYPOINTCTL_DAEMON=0

# Backend settings passed through to waypoint if you want shell-level overrides.
# Prefer backend/waypoint.yaml for structured config; use env for machine-local secrets.
# WAYPOINT_PASSWORD=change-me
