WAYPOINT_HOST=0.0.0.0
WAYPOINT_PORT=8787
WAYPOINT_PASSWORD=change-me
WAYPOINT_DATA_DIR=${HOME}/Library/Application Support/Waypoint
# Comma-separated list of allowed origins. Defaults to localhost on port 3000.
# WAYPOINT_CORS_ORIGINS=http://localhost:3000,http://100.64.0.10:3000
# Regex form for dynamic origins like Tailscale CGNAT IPs.
# WAYPOINT_CORS_ORIGIN_REGEX=^http://(localhost|127\.0\.0\.1|100\.\d{1,3}\.\d{1,3}\.\d{1,3}):\d+$
