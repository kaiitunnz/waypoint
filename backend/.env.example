WAYPOINT_HOST=0.0.0.0
WAYPOINT_PORT=8787
WAYPOINT_PASSWORD=change-me
WAYPOINT_DATA_DIR=${HOME}/Library/Application Support/Waypoint
# Comma-separated list of allowed origins. Empty by default; the regex below
# already covers localhost + Tailscale CGNAT IPs.
# WAYPOINT_CORS_ORIGINS=http://example.internal:3000
# Regex applied alongside the explicit origin list. Default below allows
# localhost, 127.0.0.1, and any Tailscale CGNAT IPv4 (100.64.0.0/10) on any
# port. Set to an empty string to disable.
# WAYPOINT_CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|100\.\d{1,3}\.\d{1,3}\.\d{1,3})(:\d+)?$
