# Waypoint backend config. All fields are optional; missing keys fall back
# to the built-in defaults. Environment variables (WAYPOINT_*) and explicit
# CLI flags override values from this file.
#
# Default location: backend/waypoint.yaml (this file's directory). Override
# with WAYPOINT_CONFIG_PATH or `waypoint serve --config <path>`.

# Bind address and port for the FastAPI server.
# host: 127.0.0.1
# port: 8787

# Shared password for /api/auth/login.
# password: change-me

# Where SQLite + per-session log directories live. Defaults to
# ${HOME}/Library/Application Support/Waypoint on macOS.
# data_dir: ~/Library/Application Support/Waypoint

# CORS — explicit origins and a regex are OR'd together. The default regex
# already covers localhost and Tailscale CGNAT IPv4 (100.64.0.0/10).
# cors_origins:
#   - http://localhost:3000
# cors_allow_origin_regex: ^https?://(localhost|127\.0\.0\.1|100\.\d{1,3}\.\d{1,3}\.\d{1,3})(:\d+)?$

# Optional: route managed Codex sessions through an SSH-tunneled remote
# Codex App Server. Useful when the heavy code-running machine is separate
# from the Mac running Waypoint.
# codex_remote:
#   enabled: true
#   ssh_destination: user@remote-host
#   ssh_bin: ssh
#   ssh_args:
#     - -i
#     - ~/.ssh/id_ed25519
#   codex_bin: codex
#   config_overrides:
#     - sandbox_mode=read_only
#   remote_env:
#     PATH: /home/user/.local/bin:/usr/local/bin:/usr/bin:/bin
#   cwd_mappings:
#     - local_prefix: ~/Local/projects
#       remote_prefix: ~/projects
